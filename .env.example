# IMS Data Fetcher - Environment Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# === REQUIRED: XIMS Login Credentials ===
IMS_LOGIN_URL=https://ims.marvellousfiber.com/Admin
IMS_USERNAME=countrylink
IMS_PASSWORD=your_password_here

# === Optional: Operational Settings ===
IMS_PAGE_SIZE=50
IMS_DATE_FORMAT=yyyy/MM/dd
IMS_RETRY_COUNT=2
IMS_CONN_TIMEOUT=30
IMS_READ_TIMEOUT=60

# === Export Configuration ===
# Options: console, csv, mysql (comma-separated for multiple)
IMS_EXPORT_FORMATS=csv

# === Optional: MySQL Export ===
IMS_MYSQL_ENABLED=false
# IMS_MYSQL_HOST=localhost
# IMS_MYSQL_PORT=3306
# IMS_MYSQL_DB=ims_renewals
# IMS_MYSQL_USER=db_user
# IMS_MYSQL_PASSWORD=db_password

# === Optional: Logging & Debug ===
IMS_DEBUG=false
IMS_DIAGNOSTIC=false
IMS_FILE_LOGGING=true
