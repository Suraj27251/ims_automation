# IMS Renewal Data Fetcher + Campaign System - Environment Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# === REQUIRED: IMS Connection ===
IMS_BASE_URL=https://ims.marvellousfiber.com
IMS_USERNAME=countrylink
IMS_PASSWORD=your_password_here

# === MySQL Database ===
MYSQL_HOST=localhost
MYSQL_USER=countrylinks_ims
MYSQL_PASSWORD=your_db_password
MYSQL_DATABASE=countrylinks_user_database
MYSQL_PORT=3306

# === WhatsApp Cloud API ===
WHATSAPP_TOKEN=your_whatsapp_cloud_api_token
WHATSAPP_PHONE_ID=your_phone_number_id
WHATSAPP_API_VERSION=v18.0

# === Campaign System Settings ===
SECRET_KEY=change-me-to-a-random-string
DEBUG=false
DUPLICATE_INTERVAL_HOURS=24
