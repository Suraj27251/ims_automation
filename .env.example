# IMS Renewal Data Fetcher - Environment Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# === REQUIRED: IMS Connection ===
IMS_BASE_URL=https://ims.marvellousfiber.com
IMS_USERNAME=countrylink
IMS_PASSWORD=your_password_here

# === MySQL Database ===
MYSQL_HOST=localhost
MYSQL_USER=countrylinks_ims
MYSQL_PASSWORD=your_db_password
MYSQL_DATABASE=countrylinks_ims_renewals
MYSQL_PORT=3306
